{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/my_app/browser",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://final-project-web-advance.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
